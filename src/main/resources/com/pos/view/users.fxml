<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pos.controller.UsersController" style="-fx-padding: 20;">
    <Label text="User Management" style="-fx-font-size: 24; -fx-font-weight: bold;"/>

    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colUsername" text="Username" prefWidth="150"/>
            <TableColumn fx:id="colFullName" text="Full Name" prefWidth="200"/>
            <TableColumn fx:id="colRole" text="Role" prefWidth="100"/>
            <TableColumn fx:id="colActive" text="Active" prefWidth="80"/>
        </columns>
    </TableView>

    <GridPane hgap="10" vgap="10">
        <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtUsername" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Password:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <PasswordField fx:id="txtPassword" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

        <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txtFullName" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Role:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <ComboBox fx:id="cmbRole" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

        <Label text="Active:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <CheckBox fx:id="chkActive" GridPane.columnIndex="1" GridPane.rowIndex="2" selected="true"/>
    </GridPane>

    <HBox spacing="10">
        <Button fx:id="btnAdd" text="Add User" onAction="#handleAdd"/>
        <Button fx:id="btnUpdate" text="Update" onAction="#handleUpdate" disable="true"/>
        <Button fx:id="btnDelete" text="Delete" onAction="#handleDelete" disable="true"/>
        <Button fx:id="btnClear" text="Clear" onAction="#handleClear"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnClose" text="Close" onAction="#handleClose"/>
    </HBox>
</VBox>
